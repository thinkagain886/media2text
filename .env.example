# =====================================================================
# 只维护这一份「根 .env」（复制本文件为 .env）。一般不需要 backend/.env。
#
# • 本机 PyCharm / uvicorn：backend 会 load 根 .env（见 backend/core/config_loader.py）。
# • Docker Compose：同样读根 .env（env_file + 下面变量用于卷挂载）。
#
# 路径推荐正斜杠（D:/MyData/...）。数据库文件放在 SQLITE_DATA_DIR 下，文件名默认 media2text.db。
# =====================================================================

# ---------- Redis（本机直连；Docker 里 compose 会改用 redis://redis）----------
REDIS_HOST=127.0.0.1
REDIS_DB_PORT=6379
REDIS_URL="redis://${REDIS_HOST}:${REDIS_DB_PORT}/0"

# ---------- Compose 端口 ----------
REDIS_PUBLISH_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ---------- 后端 ----------
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=*

# ---------- SQLite（目录 + 文件名；SQLITE_PATH 供本机 Python 打开同一文件）----------
SQLITE_DATA_DIR=./localdata/sqlite_data
SQLITE_FILENAME=media2text.db
SQLITE_PATH="${SQLITE_DATA_DIR}/${SQLITE_FILENAME}"

# ---------- FunASR / ModelScope（本机缓存目录；Compose 会把该路径挂到容器 /root/.cache/modelscope）----------
MODELSCOPE_CACHE=./localdata/modelscope_cache/hub

# ---------- 临时目录 ----------
# 本机与 Docker 想用同一磁盘目录：填绝对路径（与下方 TEMP_DIR 一致）。
# 若只在本机用相对路径 ./temp，Docker 请删去 TEMP_DIR 让 compose 使用默认 ./backend/temp 挂载。
TEMP_DIR=./localdata/temp

PRELOAD_FUNASR=false
